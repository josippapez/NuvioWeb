{
  "name": "nuvio-tv-web",
  "private": true,
  "type": "module",
  "version": "0.2.5",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "build:on-release": "node ./scripts/release-build-poller.mjs",
    "install:webos": "node ./scripts/ares-install-webos.mjs",
    "diagnose:enginefs:webos": "node ./scripts/diagnose-enginefs-webos.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "inspect:webos": "node ./scripts/ares-inspect-webos.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "logs:webos": "node ./scripts/ares-logs-webos.mjs",
    "media:webos-sim": "node --require ./scripts/localhost-listen-patch.cjs ./services/webos/runtime/media-http.cjs",
    "package:tizen": "npm run build && node ./scripts/package-tizen.mjs",
    "package:webos": "npm run build && node ./scripts/package-webos.mjs",
    "serve": "node ./scripts/serve.mjs",
    "sync": "node ./scripts/sync-wrapper.mjs",
    "sync:tizen": "node ./scripts/sync-wrapper.mjs --tizen",
    "sync:webos": "node ./scripts/sync-wrapper.mjs --webos",
    "sync:tizenbrew": "node ./scripts/sync-tizenbrew.mjs"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@webos-tools/cli": "^3.2.4",
    "@babel/plugin-transform-arrow-functions": "^7.27.1",
    "@babel/plugin-transform-async-to-generator": "^7.28.6",
    "@babel/plugin-transform-block-scoping": "^7.28.6",
    "@babel/plugin-transform-nullish-coalescing-operator": "^7.28.6",
    "@babel/plugin-transform-optional-chaining": "^7.28.6",
    "@babel/plugin-transform-regenerator": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/plugin-transform-shorthand-properties": "^7.27.1",
    "@babel/preset-env": "^7.29.2",
    "@babel/runtime": "^7.29.2",
    "@chialab/esbuild-plugin-babel": "^0.19.1",
    "@csstools/postcss-global-data": "^4.0.0",
    "autoprefixer": "^10.4.27",
    "babel-loader": "^10.1.1",
    "core-js": "^3.49.0",
    "cssnano": "^7.1.4",
    "eslint": "^10.5.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-babel": "^0.2.3",
    "globals": "^17.6.0",
    "postcss": "^8.5.9",
    "postcss-custom-properties": "^15.0.1",
    "prettier": "^3.8.4",
    "regenerator-runtime": "^0.14.1"
  },
  "dependencies": {
    "intersection-observer": "^0.12.2",
    "jszip": "^3.10.1",
    "whatwg-fetch": "^3.6.20"
  }
}
